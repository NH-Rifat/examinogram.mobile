{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/theme": ["./src/theme"],
      "@/theme/*": ["./src/theme/*"],
      "@/types": ["./src/types"],
      "@/types/*": ["./src/types/*"],
      "@/components/*": ["./src/components/*"],
      "@/utils/*": ["./src/utils/*"],
      "@/store": ["./src/store"],
      "@/store/*": ["./src/store/*"],
      "@/providers/*": ["./src/providers/*"],
      "@/constants/*": ["./src/constants/*"],
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
